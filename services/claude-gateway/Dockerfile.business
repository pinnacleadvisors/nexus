# Per-business Claude Code gateway image.
#
# Extends the base gateway (services/claude-gateway/Dockerfile) with the
# business's MCP manifest pre-installed. Driven by build args:
#
#   BUSINESS_SLUG       — used in container labels + log lines
#   MCP_PACKAGES        — space-separated list of npm packages to install
#                          globally (resolved from lib/businesses/mcp-manifest.ts
#                          by the provisioner before the Coolify build).
#
# Runtime env vars are still injected by Coolify from Doppler — this image
# only bakes in WHICH MCP packages are available, not the secrets they need.
#
# Build (locally):
#   docker build \
#     --build-arg BUSINESS_SLUG=acme-ads \
#     --build-arg MCP_PACKAGES="@nexus/mcp-memory-hq @nexus/mcp-canva" \
#     -f Dockerfile.business -t nexus-business:acme-ads services/claude-gateway/

ARG BUSINESS_SLUG=unset
ARG MCP_PACKAGES=""

# ── Stage 1: build the gateway TS sources (same as base image) ─────────────
FROM node:22-bookworm-slim AS build
WORKDIR /app

COPY package.json ./
RUN npm install --no-audit --no-fund

COPY tsconfig.json ./
COPY src ./src
RUN npm run build


# ── Stage 2: runtime ───────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS runtime
WORKDIR /app

ARG BUSINESS_SLUG
ARG MCP_PACKAGES

LABEL nexus.business.slug="${BUSINESS_SLUG}"
LABEL nexus.image.kind="per-business-claude-gateway"

RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates bash \
 && rm -rf /var/lib/apt/lists/*

# Claude CLI — pinned to latest stable major.
RUN npm install --location=global @anthropic-ai/claude-code@latest

# Per-business MCP packages. If MCP_PACKAGES is empty, this is a no-op so
# the image still builds cleanly. The script silently skips packages that
# fail to install (lets a typo in the manifest not block the whole build).
RUN sh -eu -c 'if [ -n "${MCP_PACKAGES}" ]; then \
      for pkg in ${MCP_PACKAGES}; do \
        echo "[mcp-install] $$pkg"; \
        npm install --location=global --no-audit --no-fund "$$pkg" || \
          echo "[mcp-install] FAILED for $$pkg — continuing"; \
      done; \
    else \
      echo "[mcp-install] no MCP_PACKAGES — installing foundational only"; \
    fi'

# Gateway runtime deps.
COPY package.json ./
RUN npm install --omit=dev --no-audit --no-fund

COPY --from=build /app/dist ./dist
COPY entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

VOLUME ["/root/.claude"]
ENV NEXUS_REPO_PATH=/repo
ENV CLAUDE_GATEWAY_PORT=3000
ENV NEXUS_BUSINESS_SLUG="${BUSINESS_SLUG}"
EXPOSE 3000

ENTRYPOINT ["./entrypoint.sh"]
